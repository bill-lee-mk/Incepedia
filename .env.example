# Incepedia · environment variables template
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# ─── OpenRouter (合成生成器路由) ─────────────────────────────────────
# 格式: sk-or-v1-<64 hex chars>
OPENROUTER_API_KEY=<YOUR_OPENROUTER_KEY_HERE>
# 可选:第二把 key 做并发轮换(降低限流)
# OPENROUTER_API_KEY_2=<YOUR_SECOND_OPENROUTER_KEY>

# ─── GitHub (由仓库本地 credential helper 使用) ──────────────────────
GITHUB_USERNAME=<YOUR_GITHUB_USERNAME>
# 格式: ghp_<36 char PAT> 或 github_pat_<new fine-grained PAT>
GITHUB_PAT=<YOUR_GITHUB_PAT_HERE>

# ─── 路径(通常无需修改) ─────────────────────────────────────────────
INCEPEDIA_LOCAL_ROOT=/home/ubuntu/lilei/projects/Incepedia
INCEPEDIA_NAS_ROOT=/lambda/nfs/us-south-2/incepedia_exp_bak

# ─── HF Hub / W&B (P1 阶段暂不使用) ─────────────────────────────────
# HF_TOKEN=<YOUR_HF_TOKEN>
# WANDB_API_KEY=<YOUR_WANDB_KEY>
